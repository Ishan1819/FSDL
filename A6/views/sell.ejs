<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { pageTitle: 'Sell an Item' }) %>
<body>
  <%- include('partials/header') %>

  <section class="container section narrow">
    <h1 class="section-title">Sell an Item</h1>

    <% if (submitted) { %>
      <div class="alert alert-success">
        <p><strong>Thanks, <%= title %>!</strong> Your ad has been received.</p>
        <p class="muted">
          Note: this demo does not use a database, so the ad is not actually
          saved or listed — it is only shown here as confirmation of what was submitted.
        </p>
      </div>
      <div class="submitted-summary">
        <p><span class="spec-label">Title:</span> <%= title %></p>
        <p><span class="spec-label">Category:</span> <%= category %></p>
        <p><span class="spec-label">Price:</span> &#8377;<%= Number(price).toLocaleString('en-IN') %></p>
        <p><span class="spec-label">Location:</span> <%= location %></p>
        <p><span class="spec-label">Description:</span> <%= description %></p>
      </div>
      <a href="/sell" class="btn btn-outline">Post Another Ad</a>
    <% } else { %>
      <p class="muted">Fill in the details below to list your car, bike or other used item for sale.</p>
      <form class="form" method="POST" action="/sell">
        <label for="title">Item Title</label>
        <input type="text" id="title" name="title" placeholder="e.g. Maruti Swift VDI" required />

        <label for="category">Category</label>
        <select id="category" name="category" required>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>"><%= cat %></option>
          <% }) %>
        </select>

        <label for="price">Asking Price (&#8377;)</label>
        <input type="number" id="price" name="price" placeholder="e.g. 250000" required />

        <label for="location">Location</label>
        <input type="text" id="location" name="location" placeholder="e.g. Pune, Maharashtra" required />

        <label for="description">Description</label>
        <textarea id="description" name="description" rows="5" placeholder="Describe the condition, mileage, ownership history, etc." required></textarea>

        <button type="submit" class="btn btn-primary">Post Ad</button>
      </form>
    <% } %>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
