<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { pageTitle: 'About Us' }) %>
<body>
  <%- include('partials/header') %>

  <section class="page-banner">
    <div class="container">
      <h1>About <%= companyInfo.name %></h1>
    </div>
  </section>

  <section class="container section">
    <p>
      Founded in <%= companyInfo.founded %>, <%= companyInfo.name %> has been helping travelers
      discover incredible destinations across India with thoughtfully curated packages,
      transparent pricing, and dedicated on-trip support.
    </p>

    <h2 class="section-title">Our Team</h2>
    <div class="team-grid">
      <% team.forEach(member => { %>
        <div class="team-card">
          <div class="avatar"><%= member.name.charAt(0) %></div>
          <h3><%= member.name %></h3>
          <p class="muted"><%= member.role %></p>
        </div>
      <% }) %>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
